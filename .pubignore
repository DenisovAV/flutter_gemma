# Files and directories to exclude from pub.dev package
docs/
.github/
.idea/
.vscode/
.claude/
test_reports/
**/*.md
!README.md
!CHANGELOG.md
tools/

# Build artifacts
build/
coverage/
devtools_options.yaml

# NPM files (should not be in pub package)
node_modules/
package-lock.json
package.json
vite.config.js
web/rag/node_modules/
web/rag/dist/

# Vite build artifacts (generated files with hashes)
web/*.js
web/*.js.map
# But keep source files in web/rag/
!web/rag/

# Media files (for README, not needed in package)
docs/
assets/
colabs/
training_data/

# IDE files
*.iml

# Example app model files
example/assets/models/

# Example scripts (for local test setup, not needed in package)
example/scripts/

# Test files
test/
example/build/
example/.dart_tool/
example/.idea/
example/coverage/

# Example web build artifacts (should be regenerated by users)
example/web/models/
example/web/wasm/
example/web/*.js
example/web/*.wasm
example/web/*.model
!example/web/index.html
!example/web/manifest.json
!example/web/favicon.png
!example/web/icons/

# Log files
*.log
firebase-debug.log
litertlm-server/hs_err_*.log

# Desktop - TFLite C library (downloaded at build time)
macos/Resources/tflite/

# Desktop - JAR (downloaded at build time via prepare_resources.sh)
macos/Resources/litertlm-server.jar
litertlm-server/litertlm-server.jar
**/*.jar

# Misc
test_exports.dart
trash_*
.env
.firecrawl/
example/kill

# Native prebuilts — fetched by hook/build.dart from native-v0.10.2 release
native/litert_lm/prebuilt/

# Integration tests (kept in repo for dev, not for users)
example/integration_test/

# LLVM coverage
*.profraw

# Working notes (drafts, plans, articles, investigation reports)
_notes/