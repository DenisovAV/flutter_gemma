# Files and directories to exclude from pub.dev package
docs/
.github/
.idea/
.vscode/
.claude/
test_reports/
**/*.md
!README.md
!CHANGELOG.md
tools/

# Build artifacts
build/
coverage/
devtools_options.yaml

# NPM files (should not be in pub package)
node_modules/
package-lock.json
package.json
vite.config.js
web/rag/node_modules/
web/rag/dist/

# Vite build artifacts (generated files with hashes)
web/*.js
web/*.js.map
# But keep source files in web/rag/
!web/rag/

# Media files (for README, not needed in package)
docs/
assets/
colabs/
training_data/

# IDE files
*.iml

# Example app model files
example/assets/models/

# Example scripts (for local test setup, not needed in package)
example/scripts/

# Test files
test/
example/build/
example/.dart_tool/
example/.idea/
example/coverage/

# Example web build artifacts (should be regenerated by users)
example/web/models/
example/web/wasm/
example/web/*.js
example/web/*.wasm
example/web/*.model
!example/web/index.html
!example/web/manifest.json
!example/web/favicon.png
!example/web/icons/

# Log files
*.log
firebase-debug.log
litertlm-server/hs_err_*.log

# Desktop - TFLite C library (downloaded at build time)
macos/Resources/tflite/

# Desktop - JAR (downloaded at build time via prepare_resources.sh)
macos/Resources/litertlm-server.jar
litertlm-server/litertlm-server.jar
**/*.jar

# Misc
test_exports.dart
trash_*
.env
.firecrawl/
example/kill

# Native prebuilts — fetched by hook/build.dart from native-v0.10.2 release
native/litert_lm/prebuilt/

# Training/conversion notebooks — useful for plugin dev, not for users
colabs/

# Integration tests (kept in repo for dev, not for users)
example/integration_test/

# LLVM coverage
*.profraw

# Working notes (drafts, plans, articles, investigation reports)
_notes/

# Pigeon spec — build-time input that generates lib/pigeon.g.dart.
# Consumers ship the already-generated .g.dart, they don't re-run pigeon.
pigeon.dart

# Native FFI smoke-test — compiled into a standalone binary by maintainers
# during dev, not loaded at runtime. End users don't need the .c source.
native/litert_lm/test_ffi_minimal.c

# Stray maintainer scratch files. tables.html is leftover Mac/HTML debug
# from a much older session; test_audio.txt is a 53-byte text fixture
# that's only referenced by integration tests (already excluded above).
tables.html
test_audio.txt

# Reference clone of google-ai-edge/gallery used during research — this
# is third-party Apache 2.0 source (Google's), not part of flutter_gemma.
# Should never be in the pub package.
ai-edge-gallery/

# CocoaPods lock files — environment-specific, regenerated on every
# `pod install`. pub.dev's lints flag these.
example/ios/Podfile.lock
example/macos/Podfile.lock

# Example web test HTML fixture (used by vector store dev tests).
example/web/test_vectorstore.html