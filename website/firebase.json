{
  "hosting": {
    "target": "fluttergemma",
    "public": "build/jaspr",
    "ignore": [
      "firebase.json",
      "**/.*",
      ".dart_tool/**",
      ".build.manifest",
      "packages/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/try/**",
        "destination": "/try/index.html"
      }
    ],
    "headers": [
      {
        "comment": "Hashed/static assets (images, fonts, media, css) — safe to cache forever. NOTE: .js is deliberately EXCLUDED — Jaspr/Flutter JS bundles (main.client.dart.js, *.part.js, main.dart.js, flutter*.js) are NOT content-hashed, so immutable caching pinned stale bundles and broke the mobile-menu fix on returning visitors.",
        "source": "**/*.@(css|jpg|jpeg|gif|png|svg|webp|ico|woff2|mp4|webm)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "comment": "All JS revalidates (non-hashed names). A 304 round-trip is cheap; serving a year-stale app bundle is not.",
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      }
    ]
  }
}
